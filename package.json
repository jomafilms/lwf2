{
  "name": "lwf2",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run -w @lwf/web dev",
    "build": "npm run -ws --if-present build",
    "type-check": "npm run -ws --if-present type-check",
    "db:generate": "npm run -w @lwf/database db:generate",
    "db:migrate": "npm run -w @lwf/database db:migrate",
    "db:push": "npm run -w @lwf/database db:push",
    "db:studio": "npm run -w @lwf/database db:studio"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@turf/area": "^7.3.4",
    "@turf/union": "^7.3.4",
    "class-variance-authority": "^0.7.1",
    "react-markdown": "^10.1.0"
  }
}
