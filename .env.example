# ========================================
# LWF2 Environment Variables
# Copy to .env and fill in values
# ========================================

# --- Database (Neon PostgreSQL) ---
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# --- Auth (BetterAuth) ---
BETTER_AUTH_SECRET=         # Generate: openssl rand -hex 32
BETTER_AUTH_URL=http://localhost:3000

# --- Maps (Mapbox) ---
NEXT_PUBLIC_MAPBOX_TOKEN=   # From mapbox.com dashboard
VITE_MAPBOX_TOKEN=          # Same token, Vite format

# --- LWF Plant API (no auth needed) ---
NEXT_PUBLIC_LWF_API_BASE=https://lwf-api.vercel.app/api/v1

# --- AI Agent (optional — skip for now) ---
ANTHROPIC_API_KEY=          # For AI chat features

# --- Stripe (optional — for nursery cart demo later) ---
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Email (optional — for notifications later) ---
# RESEND_API_KEY=
